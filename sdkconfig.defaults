CONFIG_BT_ENABLED=y
CONFIG_BTDM_CTRL_MODE_BTDM=y
CONFIG_BTDM_CTRL_HCI_MODE_VHCI=y
CONFIG_BT_BLUEDROID_ENABLED=y
CONFIG_BT_CLASSIC_ENABLED=y
CONFIG_BT_BLE_ENABLED=y
CONFIG_BT_HID_ENABLED=y
CONFIG_BT_HID_HOST_ENABLED=y
CONFIG_FREERTOS_CHECK_STACKOVERFLOW_PTRVAL=
CONFIG_FREERTOS_CHECK_STACKOVERFLOW_CANARY=y
CONFIG_ESP32_WIFI_NVS_ENABLED=y
CONFIG_ESP_WIFI_SOFTAP_SUPPORT=y
CONFIG_LWIP_LOCAL_HOSTNAME="hidproxy"
CONFIG_PARTITION_TABLE_SINGLE_APP=n
CONFIG_PARTITION_TABLE_SINGLE_APP_LARGE=y
# Chrome sends ~700-900 B of request headers (Sec-Ch-Ua-*, User-Agent, Cookie);
# default 512 trips a 431 once the 80-hex-char session cookie is added.
CONFIG_HTTPD_MAX_REQ_HDR_LEN=1024
# Keychron K2 HE and other BLE keyboards register 8+ INPUT-report CCC
# notifications (boot kbd, NKRO kbd, mouse, consumer, generic, battery).
# IDF's default of 5 silently drops the extras; without the keyboard
# INPUT CCC, no keys reach the host. Headroom for multi-device futures.
CONFIG_BT_GATTC_NOTIF_REG_MAX=16
